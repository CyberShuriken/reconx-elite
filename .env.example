# ============================================
# Backend Environment Variables (FastAPI)
# ============================================

# Database Configuration
DATABASE_URL=postgresql+psycopg2://reconx:reconx@postgres:5432/reconx

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production-min-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS Configuration
# Comma-separated list of allowed origins for API access
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Regex pattern for preview deployments (e.g., Vercel preview URLs)
CORS_ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app
# Frontend URL (e.g., https://reconx-elite-frontend.vercel.app)
FRONTEND_URL=

# HTTPS/Proxy Configuration
# Set to true if running behind an HTTPS proxy (e.g., Railway, Cloudflare)
HTTPS_BEHIND_PROXY=false

# Scan Configuration
SCAN_ALLOWED_SCHEMES=http,https
SCAN_THROTTLE_SECONDS=20
JS_FETCH_TIMEOUT_SECONDS=6
JS_FETCH_MAX_ASSETS=12
JS_FETCH_MAX_BYTES=200000
SCAN_NUCLEI_TARGET_CAP=300
SCAN_HEADER_PROBE_CAP=50

# Rate Limiting
REGISTER_RATE_LIMIT=10/minute
LOGIN_RATE_LIMIT=20/minute
REFRESH_RATE_LIMIT=30/minute
READ_RATE_LIMIT=60/minute
WRITE_RATE_LIMIT=12/minute
AI_RATE_LIMIT=10/minute
AUTH_RATE_LIMIT=10/minute
SCAN_RATE_LIMIT=12/minute
REPORT_RATE_LIMIT=30/minute
TICKETING_RATE_LIMIT=20/minute

# Scheduled Scans
SCHEDULED_SCAN_POLL_MINUTES=10

# Advanced Reconnaissance Settings
ADVANCED_RECON_ENABLED=true
DEFAULT_SCAN_MODE=balanced
MAX_PARAMETER_DISCOVERY_ENDPOINTS=50
MAX_CONTENT_FUZZING_REQUESTS=100
MAX_ADAPTIVE_ANALYSIS_ENDPOINTS=20
PARAMETER_DISCOVERY_TIMEOUT_SECONDS=300
CONTENT_FUZZING_TIMEOUT_SECONDS=600
ADAPTIVE_ANALYSIS_TIMEOUT_SECONDS=300

# Passive DNS Settings
SCAN_CRTSH_TIMEOUT_SECONDS=90.0
SCAN_CRTSH_MAX_NAMES=5000
SCAN_GITHUB_SUBDOMAINS_TIMEOUT_SECONDS=180
SCAN_GITHUB_SUBDOMAINS_MAX_NAMES=2000

# Wordlists Path (for worker-full with Seclists)
SECLISTS_BASE_PATH=

# Active Discovery Caps
SCAN_ACTIVE_DNS_MAX_LABELS=500
SCAN_FFUF_TIMEOUT_SECONDS=300
SCAN_WAYBACK_MAX_URLS=5000
SCAN_KATANA_TIMEOUT_SECONDS=600
SCAN_KATANA_MAX_URLS=2000

# Port/Screenshots/WAF Settings
SCAN_NMAP_TIMEOUT_SECONDS=600
SCAN_NMAP_MAX_HOSTS=50
SCAN_GOWITNESS_TIMEOUT_SECONDS=900
SCAN_WAFW00F_TIMEOUT_SECONDS=120

# Aggressive Scanning (requires enable_aggressive_scanning=true)
ENABLE_AGGRESSIVE_SCANNING=false
SCAN_AGGRESSIVE_TIMEOUT_SECONDS=900
SCAN_SQLMAP_MAX_URLS=3
SCAN_DALFOX_MAX_URLS=3
SCAN_MASSCAN_MAX_HOSTS=5
SCAN_MASSCAN_RATE=500

# Nuclei OOB (optional self-hosted interactsh)
INTERACTSH_SERVER_URL=

# Database Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30

# Redis Cache
REDIS_CACHE_TTL=60

# Backup Configuration
BACKUP_DEST_PATH=/backups
BACKUP_RETENTION_DAYS=7

# Metrics
METRICS_ENABLED=true

# Ticketing Integration (Jira)
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Bug

# GitHub Integration
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_ASSIGNEE=

# GitLab Integration
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
GITLAB_PROJECT_ID=
GITLAB_ASSIGNEE_ID=

# Takeover CNAME Indicators
TAKEOVER_CNAME_INDICATORS=amazonaws.com,azurewebsites.net,herokudns.com,github.io,cloudfront.net,trafficmanager.net,fastly.net,readme.io,pantheonsite.io

# AI Keys
GEMINI_API_KEY=
OPENROUTER_KEY=
OR_KEY_NEMOTRON_NANO=
OR_KEY_NEMOTRON_SUPER=
OR_KEY_NEMOTRON_SUPER_ALT=
OR_KEY_QWEN_CODER=
OR_KEY_GLM_45=
OPENROUTER_API_KEY_SECONDARY=
OPENROUTER_API_KEY_TERTIARY=
OR_KEY_MINIMAX=
OR_KEY_GPT_OSS_120B=
OR_KEY_GPT_OSS_20B=

# AI Provider Settings
AI_SCAN_PROVIDER=gemini
AI_SCAN_MODEL=gemini-1.5-flash
AI_ANALYZE_PROVIDER=gemini
AI_ANALYZE_MODEL=gemini-1.5-flash
AI_REPORT_PROVIDER=gemini
AI_REPORT_MODEL=gemini-1.5-pro

# AI Resilience Settings
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_SECONDS=15.0
GEMINI_RETRY_MAX_SLEEP_SECONDS=90.0
AI_MAX_INPUT_CHARS=12000

# Supabase Integration (frontend auth bridge)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Callback URL
CALLBACK_URL=http://localhost:8000

# Notification Webhooks
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================
# Frontend Environment Variables (React + Vite)
# ============================================

# API Backend URL (Railway production URL). Prefer VITE_API_URL.
VITE_API_URL=http://localhost:8000
# Backward-compatible alias for existing deployments.
VITE_API_BASE_URL=

# WebSocket URL (optional - defaults to derived from VITE_API_URL)
VITE_WS_URL=

# Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
