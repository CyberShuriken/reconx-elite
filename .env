# ── Database Connection Pool ──────────────────────────────────────────────────
# SQLAlchemy connection pool size (number of persistent connections)
DB_POOL_SIZE=20
# Maximum overflow connections above pool_size
DB_MAX_OVERFLOW=30
# Seconds before a connection is recycled (prevents stale connections)
DB_POOL_RECYCLE=3600
# Seconds to wait for a connection before raising a timeout error
DB_POOL_TIMEOUT=30

# ── HTTPS / Proxy ─────────────────────────────────────────────────────────────
# Set to true when the backend is behind a TLS-terminating reverse proxy
# Enables the Strict-Transport-Security (HSTS) response header
HTTPS_BEHIND_PROXY=false

# ── Redis Cache ───────────────────────────────────────────────────────────────
# Default TTL in seconds for cached API responses
REDIS_CACHE_TTL=60

# ── Database Backup ───────────────────────────────────────────────────────────
# Directory path inside the backup container where dumps are stored
BACKUP_DEST_PATH=/backups
# Number of days to retain backup files before pruning
BACKUP_RETENTION_DAYS=7
# Seconds between backup runs (default: 86400 = 24 hours)
BACKUP_INTERVAL_SECONDS=86400

# ── Metrics ───────────────────────────────────────────────────────────────────
# Set to false to disable the /metrics Prometheus endpoint
METRICS_ENABLED=true

# ── Monitoring ────────────────────────────────────────────────────────────────
